{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blacpg/qld-re-compliance/schema/scenario.schema.json",
  "title": "Test scenario",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "jurisdiction", "module", "question_type", "question", "expected_outcome"],
  "properties": {
    "id": { "type": "string", "pattern": "^SCN-[0-9]{3}$" },
    "jurisdiction": { "type": "string", "enum": ["QLD", "OUT_OF_SCOPE"] },
    "module": {
      "type": "string",
      "enum": [
        "form-6-appointment",
        "commission",
        "marketing-and-price",
        "offers-and-negotiation",
        "seller-disclosure",
        "cooling-off",
        "out-of-scope"
      ]
    },
    "question_type": {
      "type": "string",
      "enum": ["rule_check", "document_review", "agent_script", "risk_assessment", "checklist"]
    },
    "question": { "type": "string", "minLength": 1 },
    "expected_outcome": {
      "description": "A single acceptable outcome, or a list of acceptable outcomes when more than one resolution is legitimately correct (e.g. a rule that both answers and requires escalation).",
      "oneOf": [
        {
          "type": "string",
          "enum": ["answered", "refused_unsourced", "refused_out_of_scope", "escalated", "uncertain"]
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["answered", "refused_unsourced", "refused_out_of_scope", "escalated", "uncertain"]
          }
        }
      ]
    },
    "expected_rule_ids": { "type": "array", "items": { "type": "string" } },
    "expected_source_ids": { "type": "array", "items": { "type": "string" } },
    "must_include": { "type": "array", "items": { "type": "string" } },
    "must_not_include": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": ["string", "null"] }
  }
}
