{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blacpg/qld-re-compliance/schema/rule.schema.json",
  "title": "Compliance rule",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "jurisdiction",
    "module",
    "question_types",
    "status",
    "verification_status",
    "risk_level",
    "authority_tier",
    "applies_when",
    "requirement",
    "sources",
    "agent_action",
    "human_escalation_required",
    "last_source_check",
    "next_review_due"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^RULE-[A-Z0-9]+-[0-9]{3}$" },
    "title": { "type": "string", "minLength": 1 },
    "jurisdiction": { "type": "string", "enum": ["QLD"] },
    "module": {
      "type": "string",
      "enum": [
        "form-6-appointment",
        "commission",
        "marketing-and-price",
        "offers-and-negotiation",
        "seller-disclosure",
        "cooling-off"
      ]
    },
    "question_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["rule_check", "document_review", "agent_script", "risk_assessment", "checklist"]
      }
    },
    "status": { "type": "string", "enum": ["active", "draft", "superseded", "retired"] },
    "verification_status": {
      "type": "string",
      "enum": ["verified", "partially_verified", "unverified", "needs_review"]
    },
    "verification_note": { "type": ["string", "null"] },
    "risk_level": { "type": "string", "enum": ["high", "medium", "low"] },
    "authority_tier": {
      "type": "string",
      "enum": ["legislation", "regulation", "statutory_form", "regulator_guidance", "industry_commentary", "internal_policy"]
    },
    "applies_when": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "does_not_apply_when": { "type": "array", "items": { "type": "string" } },
    "requirement": { "type": "string", "minLength": 1 },
    "detail": { "type": ["string", "null"] },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id", "pinpoint", "source_role"],
        "properties": {
          "source_id": { "type": "string", "pattern": "^SRC-[A-Z0-9-]+$" },
          "pinpoint": { "type": ["string", "null"] },
          "source_role": { "type": "string", "enum": ["primary", "supporting"] },
          "url": { "type": ["string", "null"] },
          "quote": { "type": ["string", "null"] }
        }
      }
    },
    "agent_action": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "agent_wording": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "safe_version": { "type": ["string", "null"] },
        "avoid_saying": { "type": "array", "items": { "type": "string" } }
      }
    },
    "exceptions": { "type": "array", "items": { "type": "string" } },
    "penalty": { "type": ["string", "null"] },
    "human_escalation_required": { "type": "boolean" },
    "escalation_reason": { "type": "array", "items": { "type": "string" } },
    "related_rules": { "type": "array", "items": { "type": "string", "pattern": "^RULE-[A-Z0-9]+-[0-9]{3}$" } },
    "last_source_check": { "type": "string", "format": "date" },
    "next_review_due": { "type": "string", "format": "date" },
    "event_triggered_review": {
      "type": "boolean",
      "$comment": "If true (default when omitted), the rule must be reviewed before next_review_due whenever an official source changes (amendment, new OFT guidance, new form version, relevant court decision)."
    },
    "tags": { "type": "array", "items": { "type": "string" } }
  },
  "allOf": [
    {
      "$comment": "verification_note must be a non-empty string whenever the rule is not fully verified.",
      "if": {
        "properties": { "verification_status": { "not": { "const": "verified" } } }
      },
      "then": {
        "required": ["verification_note"],
        "properties": { "verification_note": { "type": "string", "minLength": 1 } }
      }
    },
    {
      "$comment": "If escalation is required, a reason must be given.",
      "if": { "properties": { "human_escalation_required": { "const": true } } },
      "then": {
        "required": ["escalation_reason"],
        "properties": { "escalation_reason": { "type": "array", "minItems": 1 } }
      }
    }
  ]
}
